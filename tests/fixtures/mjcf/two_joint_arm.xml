<mujoco model="two_joint_arm">
  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>
  <default>
    <geom contype="0" conaffinity="0"/>
    <joint damping="0.5"/>
  </default>
  <worldbody>
    <body name="link1" pos="0 0 0">
      <joint name="j1" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
      <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.02"/>
      <body name="link2" pos="0.3 0 0">
        <joint name="j2" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
        <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.02"/>
        <body name="end_effector" pos="0.3 0 0">
          <geom name="ee_sphere" type="sphere" size="0.03"/>
          <body name="finger" pos="0 0 0">
            <joint name="j_grip" type="slide" axis="0 1 0" range="-0.04 0.04" damping="1.0"/>
            <geom name="finger_tip" type="box" size="0.005 0.005 0.01" pos="0 0.04 0"
                  contype="1" conaffinity="1"/>
          </body>
        </body>
      </body>
    </body>
    <body name="block" pos="0.35 0.20 0.01">
      <geom name="block_geom" type="box" size="0.02 0.02 0.02" contype="1" conaffinity="1"/>
    </body>
  </worldbody>
  <actuator>
    <position name="a1" joint="j1" kp="50"/>
    <position name="a2" joint="j2" kp="50"/>
    <position name="a_grip" joint="j_grip" kp="100"/>
  </actuator>
</mujoco>
